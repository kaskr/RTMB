## Use 'RTMB_PARALLEL' to select parallel build
RTMB_PARALLEL_FLAGS = `"$(R_HOME)/bin$(R_ARCH_BIN)/Rscript" -e "cat('$(SHLIB_OPENMP_CXXFLAGS)'[Sys.getenv('RTMB_PARALLEL')!=''])"`
PKG_CXXFLAGS = $(RTMB_PARALLEL_FLAGS)
PKG_CPPFLAGS=-DTMBAD_FRAMEWORK -DTMBAD_INDEX_TYPE=uint64_t -DTMB_EIGEN_DISABLE_WARNINGS -DTMB_SAFEBOUNDS -DEIGEN_FFTW_DEFAULT -I$(LIB_FFTW)/include
PKG_LIBS=-L$(LIB_FFTW)/lib -l fftw3 $(RTMB_PARALLEL_FLAGS)
